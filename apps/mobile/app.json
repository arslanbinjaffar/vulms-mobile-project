{
  "expo": {
    "name": "VU LMS",
    "slug": "vu-lms",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "vulms",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B2A4A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "pk.edu.vu.lms"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B2A4A"
      },
      "package": "pk.edu.vu.lms"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6B4C9A"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "arslanjaffarpixelpks-team",
    "extra": {
      "eas": {
        "projectId": "4344eab1-c68a-43e8-85ef-5003cb66c1a1"
      }
    }
  }
}
