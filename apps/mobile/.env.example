# Public API base URL baked into Expo / EAS builds (no trailing slash).
# Local default (if unset): http://localhost:8788 (Android emulator: http://10.0.2.2:8788)
#
# After Vercel deploy, set to your project URL, e.g.:
# EXPO_PUBLIC_API_URL=https://vu-lms-xxxx.vercel.app

EXPO_PUBLIC_API_URL=https://YOUR-PROJECT.vercel.app
