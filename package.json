{
  "name": "vu-lms",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:api": "pnpm --filter @vu-lms/api dev",
    "dev:mobile": "pnpm --filter @vu-lms/mobile start",
